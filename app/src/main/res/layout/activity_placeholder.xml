<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_screen_gradient"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:padding="@dimen/space_xl">

    <ImageButton
        android:id="@+id/button_back"
        style="@style/Widget.SehatSaathi.ToolbarButton"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:layout_gravity="start"
        android:contentDescription="@string/back"
        android:src="@drawable/ic_arrow_back_small" />

    <FrameLayout
        android:layout_width="76dp"
        android:layout_height="76dp"
        android:layout_marginTop="@dimen/space_xxl"
        android:background="@drawable/bg_icon_circle_mint"
        android:padding="20dp">

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:src="@drawable/ic_medical_services"
            app:tint="@color/mint_500" />
    </FrameLayout>

    <TextView
        android:id="@+id/text_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/space_lg"
        android:textColor="@color/text_primary"
        android:textSize="26sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/text_message"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/space_md"
        android:gravity="center"
        android:text="@string/placeholder_message"
        android:textColor="@color/text_secondary"
        android:textSize="16sp" />
</LinearLayout>
